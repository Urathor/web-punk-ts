{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "skipLibCheck": true,
    "types": []
  },
  "include": ["src"],
  "exclude": ["tests", "src/main.ts", "src/**/*.test.ts"]
}
