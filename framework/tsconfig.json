{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "ESNext",
    "moduleResolution": "Bundler",
    "lib":              ["ES2022", "DOM"],
    "strict":           true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "paths": {
      "@engine/*": ["./src/*"]
    },
    "rootDir":          ".",
    "outDir":           "dist",
    "sourceMap":        true,
    "resolveJsonModule": true,
    "skipLibCheck":     true,
    "types":            ["vitest/globals"]
  },
  "include": ["src", "tests"]
}
