{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "ESNext",
    "moduleResolution": "Bundler",
    "lib":              ["ES2022", "DOM"],
    "strict":           true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "paths": {
      "@engine/*": [
        "./node_modules/webpunk.ts/src/*",
        "../node_modules/webpunk.ts/src/*",
        "../framework/src/*"
      ]
    },
    "rootDir":          "src",
    "outDir":           "dist",
    "sourceMap":        true,
    "resolveJsonModule": true,
    "skipLibCheck":     true,
    "types":            ["vite/client"]
  },
  "include": ["src"]
}
